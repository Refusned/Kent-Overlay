# ═══════════════════════════════════════════════════════
#  Kent AI Assistant — Переменные окружения
#  Создаётся автоматически через configure.sh
#  или вручную по этому шаблону.
# ═══════════════════════════════════════════════════════

# ── CORE (обязательно) ─────────────────────────────────
# Без этих переменных Kent не запустится.

OPENCLAW_GATEWAY_TOKEN=          # Генерируется deploy.sh (openssl rand -hex 16)
OPENCLAW_HOOKS_TOKEN=            # Отдельный токен для хуков (генерируется deploy.sh)
TELEGRAM_BOT_TOKEN=              # Получить у @BotFather в Telegram
CLIENT_TELEGRAM_ID=              # Ваш числовой Telegram ID
CLIENT_NAME=                     # Имя клиента (для персонализации)

# Модели + все скиллы: работают через `codex login` (OAuth через подписку ChatGPT Plus/Pro)
# Codex CLI устанавливается автоматически: pnpm add -g @openai/codex
# После установки: codex login (откроет браузер для авторизации)
# Изображения: через `openclaw auth login openai` (ChatGPT OAuth, без API-ключа)

# ── КЛИЕНТ ─────────────────────────────────────────────
CLIENT_ROLE=                     # Роль: предприниматель, маркетолог, юрист...
CLIENT_TZ=Europe/Moscow          # Часовой пояс (для cron-задач)
CLIENT_LANG=ru                   # Язык общения
BOT_NAME=Kent                    # Имя бота

# ── GOOGLE (email-triage, lead-capture, finance-tracker, content-calendar, crm-notes) ──
# Нужен Google Cloud проект с OAuth 2.0. Подробности: docs/INTEGRATIONS.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── TWITTER/X (social-drafts) ──────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=

# ── МЕДИА ──────────────────────────────────────────────
ELEVENLABS_API_KEY=              # TTS озвучка (elevenlabs-tts ClawHub)

# ── ПОИСК ──────────────────────────────────────────────
TAVILY_API_KEY=                  # Опционально (tavily-search ClawHub)

# ── УМНЫЙ ДОМ (alice-smarthome) ────────────────────────
YANDEX_OAUTH_TOKEN=              # Yandex OAuth для IoT API
YANDEX_IOT_API_URL=https://api.iot.yandex.net/v1.0

# ── ГРУППЫ TELEGRAM (опционально) ──────────────────────
GROUP_1_ID=                      # ID первой группы (пусто = не используется)
GROUP_2_ID=                      # ID второй группы

# ── ОПЕРАТОР (мониторинг и алерты) ─────────────────────
OPERATOR_TELEGRAM_BOT_TOKEN=     # Бот для системных уведомлений
OPERATOR_TELEGRAM_CHAT_ID=       # Chat ID оператора
OPENCLAW_DISABLE_BONJOUR=1

# ── ВЕРСИЯ ─────────────────────────────────────────────
OPENCLAW_VERSION=2026.4.10       # Привязана к конкретной версии
