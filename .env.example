# === ОБЯЗАТЕЛЬНЫЕ ===
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_HOOKS_TOKEN=              # Отдельный токен для хуков (генерируется автоматически deploy.sh)
TELEGRAM_BOT_TOKEN=
# Модели + все скиллы: работают через `codex login` (OAuth через подписку ChatGPT Plus/Pro)
# Codex CLI устанавливается автоматически: pnpm add -g @openai/codex
# После установки: codex login (откроет браузер для авторизации)
# Поиск, SEO, Humanizer, браузинг, генерация контента: всё через Codex подписку
# Изображения: через `openclaw auth login openai` (ChatGPT OAuth, без API-ключа)

# === GOOGLE (Gmail, Calendar, Drive) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# === СОЦСЕТИ ===
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=

# === МЕДИА ===
ELEVENLABS_API_KEY=
# Генерация изображений: через `openclaw auth login openai` (OAuth, без API-ключа)

# === ПОИСК ===
# Tavily Search: опционально. Без ключа — используется Agent Browser через Codex
# TAVILY_API_KEY=

# === УМНЫЙ ДОМ (Яндекс Алиса) ===
YANDEX_OAUTH_TOKEN=           # OAuth-токен Яндекс ID (https://oauth.yandex.ru)
YANDEX_IOT_API_URL=https://api.iot.yandex.net/v1.0

# === КЛИЕНТ ===
CLIENT_NAME=
CLIENT_ROLE=                     # Должность/род деятельности клиента
CLIENT_TZ=Europe/Moscow
CLIENT_LANG=ru
CLIENT_TELEGRAM_ID=
BOT_NAME=Kent

# === ВЕРСИИ ===
OPENCLAW_VERSION=2026.4.10       # Закреплённая версия OpenClaw (проверена при деплое)

# === ГРУППЫ (опционально) ===
GROUP_1_ID=                          # Telegram group ID (получить через @userinfobot в группе)
GROUP_2_ID=

# === ОПЕРАТОР ===
OPERATOR_TELEGRAM_BOT_TOKEN=     # отдельный бот для алертов
OPERATOR_TELEGRAM_CHAT_ID=       # ID оператора для уведомлений
OPENCLAW_DISABLE_BONJOUR=1
