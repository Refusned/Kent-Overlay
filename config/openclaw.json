{
  // ═══════════════════════════════════════════════════════════════
  //  OpenClaw — единый конфиг для продукта Kent AI Assistant
  //  Формат: JSON5 (допускаются комментарии)
  //  Совместимость: OpenClaw 2026.4.x
  // ═══════════════════════════════════════════════════════════════

  // ── Шлюз и безопасность ──────────────────────────────────────
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["http://localhost"],
      "allowInsecureAuth": false,
      "dangerouslyDisableDeviceAuth": false
    },
    "channelHealthCheckMinutes": 5,
    "channelStaleEventThresholdMinutes": 30,
    "channelMaxRestartsPerHour": 10
  },

  // ── Настройки агентов по умолчанию ───────────────────────────
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "off"
      },
      "params": {
        "cacheRetention": "short"
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h",
        "keepLastAssistants": 3
      },
      "compaction": {
        "reserveTokensFloor": 40000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000
        }
      }
    }
  },

  // ── Память ───────────────────────────────────────────────────
  "memory": {
    "backend": "builtin"
  },

  // ── Инструменты (tools) ──────────────────────────────────────
  "tools": {
    "profile": "full",
    "deny": [
      "group:automation",
      "sessions_spawn",
      "nodes",
      "canvas",
      "llm_task"
    ]
  },

  // ── Подтверждения (approvals) ────────────────────────────────
  // YOLO mode: платформа не запрашивает подтверждение на exec.
  // Kent всё равно спрашивает подтверждение на Tier 2 действия
  // (email, публикации, умный дом) через AGENTS.md и SECURITY.md.
  "approvals": {
    "exec": {
      "enabled": false
    }
  },

  // ── Профили авторизации ──────────────────────────────────────
  // Авторизация через Codex CLI (codex login), токен хранится в ~/.codex/auth.json
  // OpenClaw автоматически подхватывает его как провайдер openai-codex
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      }
    },
    "order": {
      "openai-codex": ["openai-codex:default"]
    }
  },

  // ── Хуки (webhooks) ──────────────────────────────────────────
  "hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": "${OPENCLAW_HOOKS_TOKEN}",
    "defaultSessionKey": "hook:ingress",
    "allowedAgentIds": ["hooks", "main"],
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": { "enabled": true },
        "bootstrap-extra-files": {
          "enabled": true,
          "patterns": ["SOUL.md", "SECURITY.md", "AGENTS.md", "IDENTITY.md"]
        },
        "command-logger": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  },

  // ── Канал Telegram ───────────────────────────────────────────
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "allowFrom": ["${CLIENT_TELEGRAM_ID}"],
      "streaming": {
        "mode": "partial",
        "chunkMode": "newline"
      },
      "textChunkLimit": 4000,
      "linkPreview": false,
      "ackReaction": "\ud83d\udc54",
      "groups": {
        "*": {
          "requireMention": true
        },
        "${GROUP_1_ID}": {
          "enabled": true
        },
        "${GROUP_2_ID}": {
          "enabled": true
        }
      },
      "healthMonitor": {
        "enabled": true
      },
      "customCommands": [
        { "command": "help",      "description": "\u0421\u043f\u0440\u0430\u0432\u043a\u0430 \u043f\u043e \u043a\u043e\u043c\u0430\u043d\u0434\u0430\u043c \u0431\u043e\u0442\u0430" },
        { "command": "lead",      "description": "\u0421\u043e\u0437\u0434\u0430\u0442\u044c \u0438\u043b\u0438 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u0430\u0442\u044c \u043b\u0438\u0434" },
        { "command": "content",   "description": "\u0413\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u044f \u043a\u043e\u043d\u0442\u0435\u043d\u0442\u0430 \u0434\u043b\u044f \u0441\u043e\u0446\u0441\u0435\u0442\u0435\u0439" },
        { "command": "faq",       "description": "\u0427\u0430\u0441\u0442\u043e \u0437\u0430\u0434\u0430\u0432\u0430\u0435\u043c\u044b\u0435 \u0432\u043e\u043f\u0440\u043e\u0441\u044b" },
        { "command": "brief",     "description": "\u0421\u043e\u0441\u0442\u0430\u0432\u0438\u0442\u044c \u0431\u0440\u0438\u0444 \u0434\u043b\u044f \u0437\u0430\u0434\u0430\u0447\u0438" },
        { "command": "home",      "description": "\u0412\u0435\u0440\u043d\u0443\u0442\u044c\u0441\u044f \u0432 \u0433\u043b\u0430\u0432\u043d\u043e\u0435 \u043c\u0435\u043d\u044e" },
        { "command": "draw",      "description": "\u0421\u0433\u0435\u043d\u0435\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435" },
        { "command": "slides",    "description": "\u0421\u043e\u0437\u0434\u0430\u0442\u044c \u043f\u0440\u0435\u0437\u0435\u043d\u0442\u0430\u0446\u0438\u044e" },
        { "command": "smm",       "description": "\u041f\u043b\u0430\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 SMM-\u043f\u0443\u0431\u043b\u0438\u043a\u0430\u0446\u0438\u0439" },
        { "command": "code",      "description": "\u041f\u043e\u043c\u043e\u0449\u044c \u0441 \u043a\u043e\u0434\u043e\u043c \u0438 \u0441\u043a\u0440\u0438\u043f\u0442\u0430\u043c\u0438" },
        { "command": "crm",       "description": "\u0423\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u043a\u043b\u0438\u0435\u043d\u0442\u0441\u043a\u043e\u0439 \u0431\u0430\u0437\u043e\u0439" },
        { "command": "broadcast", "description": "\u041c\u0430\u0441\u0441\u043e\u0432\u0430\u044f \u0440\u0430\u0441\u0441\u044b\u043b\u043a\u0430 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0439" },
        { "command": "mail",      "description": "\u041f\u0440\u043e\u0432\u0435\u0440\u0438\u0442\u044c \u043f\u043e\u0447\u0442\u0443 \u0438 \u0434\u0430\u0439\u0434\u0436\u0435\u0441\u0442" },
        { "command": "doc",       "description": "\u0421\u043e\u0437\u0434\u0430\u0442\u044c \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442 (\u0441\u0447\u0451\u0442, \u0434\u043e\u0433\u043e\u0432\u043e\u0440, \u0430\u043a\u0442)" },
        { "command": "finance",   "description": "\u0424\u0438\u043d\u0430\u043d\u0441\u044b: \u0434\u043e\u0445\u043e\u0434\u044b, \u0440\u0430\u0441\u0445\u043e\u0434\u044b, \u043e\u0442\u0447\u0451\u0442" },
        { "command": "humanize",  "description": "\u041e\u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0438\u0442\u044c AI-\u0442\u0435\u043a\u0441\u0442" },
        { "command": "recipes",   "description": "\u041a\u0430\u0442\u0430\u043b\u043e\u0433 \u0433\u043e\u0442\u043e\u0432\u044b\u0445 \u0440\u0435\u0446\u0435\u043f\u0442\u043e\u0432 \u041a\u0435\u043d\u0442\u0411\u0430\u0439\u0442\u0441" },
        { "command": "settings",  "description": "\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u0431\u043e\u0442\u0430" },
        { "command": "feedback",  "description": "\u041e\u0441\u0442\u0430\u0432\u0438\u0442\u044c \u043e\u0442\u0437\u044b\u0432 \u0438\u043b\u0438 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0435" },
        { "command": "status",    "description": "\u0422\u0435\u043a\u0443\u0449\u0438\u0439 \u0441\u0442\u0430\u0442\u0443\u0441 \u0441\u0438\u0441\u0442\u0435\u043c\u044b" }
      ]
    }
  },

  // ── Медиа ────────────────────────────────────────────────────
  "media": {
    "preserveFilenames": true
  },

  // ── Навыки (skills) — все встроенные разрешены ────────────────
  "skills": {
    "allowBundled": [
      "1password",
      "apple-notes",
      "apple-reminders",
      "bear-notes",
      "blogwatcher",
      "blucli",
      "bluebubbles",
      "camsnap",
      "canvas",
      "clawhub",
      "coding-agent",
      "discord",
      "eightctl",
      "gemini",
      "gh-issues",
      "gifgrep",
      "github",
      "gog",
      "goplaces",
      "healthcheck",
      "himalaya",
      "imsg",
      "mcporter",
      "model-usage",
      "nano-pdf",
      "node-connect",
      "notion",
      "obsidian",
      "openai-whisper",
      "openai-whisper-api",
      "openhue",
      "oracle",
      "ordercli",
      "peekaboo",
      "sag",
      "session-logs",
      "sherpa-onnx-tts",
      "skill-creator",
      "slack",
      "songsee",
      "sonoscli",
      "spotify-player",
      "summarize",
      "taskflow",
      "taskflow-inbox-triage",
      "things-mac",
      "tmux",
      "trello",
      "video-frames",
      "voice-call",
      "wacli",
      "weather",
      "xurl"
    ],
    "install": {
      "nodeManager": "pnpm"
    }
  },

  // ── Плагины ──────────────────────────────────────────────────
  "plugins": {
    "enabled": true
  },

  // ── Планировщик (cron) ───────────────────────────────────────
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2,
    "sessionRetention": "24h",
    "runLog": {
      "maxBytes": "2mb",
      "keepLines": 2000
    }
  },

  // ── Сессии ───────────────────────────────────────────────────
  "session": {
    "dmScope": "per-channel-peer"
  },

  // ── Логирование ──────────────────────────────────────────────
  "logging": {
    "level": "info",
    "consoleLevel": "warn",
    "redactSensitive": "tools",
    "file": "~/.openclaw/logs/openclaw.log"
  },

  // ── Обновления ───────────────────────────────────────────────
  "update": {
    "channel": "stable"
  },

  // ── Сообщения ────────────────────────────────────────────────
  "messages": {
    "responsePrefix": "",
    "ackReactionScope": "direct",
    "removeAckAfterReply": true,
    "queue": {
      "mode": "collect",
      "debounceMs": 2000,
      "cap": 10
    }
  }
}
