# Docker-specific overrides
# Используйте этот файл для переопределения переменных в Docker-среде
# Скопируйте в docker/.env и заполните

# Версия образа
OPENCLAW_IMAGE_TAG=latest
BROWSER_IMAGE_TAG=latest

# Лимиты ресурсов (можно увеличить при необходимости)
# MEM_LIMIT_OPENCLAW=2g
# MEM_LIMIT_BROWSER=2g
